# --- Config form: style descriptions ---
msgid "Uses the built-in Omeka citation format without any modification."
msgstr "Uzas la enkonstruitan citaĵoformaton de Omeka sen ia ajn ŝanĝo."

msgid "Author-date style published by the American Psychological Association. Widely used in social sciences, education and psychology."
msgstr "Aŭtor-data stilo eldonita de la Amerika Psikologia Asocio. Vaste uzata en sociaj sciencoj, edukado kaj psikologio."

msgid "Style published by the University of Chicago Press. Widely used in history, arts and social sciences."
msgstr "Stilo eldonita de la Universitato de Ĉikago. Vaste uzata en historio, artoj kaj sociaj sciencoj."

msgid "Author-date style widely used in UK universities and in natural and social sciences."
msgstr "Aŭtor-data stilo vaste uzata en britaj universitatoj kaj en naturaj kaj sociaj sciencoj."

msgid "Numbered reference style published by the Institute of Electrical and Electronics Engineers. Standard in engineering, computer science and technology."
msgstr "Numerita referenca stilo eldonita de la Instituto de Elektraj kaj Elektronikaj Inĝenieroj. Norma en inĝenierado, komputado kaj teknologio."

msgid "Style published by the Modern Language Association. Common in humanities, literature and language studies."
msgstr "Stilo eldonita de la Moderna Lingva Asocio. Ofta en homansciencoj, literaturo kaj lingvostudoj."

msgid "Chicago-based style used in Wikipedia references. Suitable for encyclopaedic and general-purpose archives."
msgstr "Ĉikago-bazita stilo uzata en Vikipediaj referencoj. Taŭga por enciklopediaj kaj ĝeneralcelaj arkivoj."

# --- Config form: examples ---
msgid "Zamenhof, Lazaro Ludoviko, \"Unua Libro,\" <em>Omeka Test</em>, last accessed March 04, 2026, http://example.com"
msgstr "Zamenhof, Lazaro Ludoviko, \"Unua Libro,\" <em>Omeka Test</em>, laste konsultita la 4-an de marto 2026, http://example.com"

msgid "Zamenhof, L. L. (1887). <em>Unua Libro</em>. Kelter. Retrieved March 4, 2026, from http://example.com"
msgstr "Zamenhof, L. L. (1887). <em>Unua Libro</em>. Kelter. Prenita la 4-an de marto 2026 de http://example.com"

msgid "Zamenhof, Lazaro Ludoviko. <em>Unua Libro</em>. Kelter, 1887. Accessed March 4, 2026. http://example.com"
msgstr "Zamenhof, Lazaro Ludoviko. <em>Unua Libro</em>. Kelter, 1887. Konsultita la 4-an de marto 2026. http://example.com"

msgid "Zamenhof, L. L. (1887) <em>Unua Libro</em>. Kelter. Available at: http://example.com (Accessed: 4 March 2026)"
msgstr "Zamenhof, L. L. (1887) <em>Unua Libro</em>. Kelter. Disponebla ĉe: http://example.com (Konsultita: la 4-an de marto 2026)"

msgid "[1] L. L. Zamenhof, <em>Unua Libro</em>, Kelter, 1887. Accessed: Mar. 4, 2026. [Online]. Available: http://example.com"
msgstr "[1] L. L. Zamenhof, <em>Unua Libro</em>, Kelter, 1887. Konsultita: la 4-an de mar. 2026. [Rete]. Disponebla: http://example.com"

msgid "Zamenhof, Lazaro Ludoviko. <em>Unua Libro</em>. Kelter, 1887. Accessed 4 Mar. 2026. http://example.com"
msgstr "Zamenhof, Lazaro Ludoviko. <em>Unua Libro</em>. Kelter, 1887. Konsultita la 4-an de mar. 2026. http://example.com"

msgid "Zamenhof Lazaro Ludoviko (1887), <em>Unua Libro</em>, Kelter, accessed March 4th, 2026, http://example.com"
msgstr "Zamenhof Lazaro Ludoviko (1887), <em>Unua Libro</em>, Kelter, konsultita la 4-an de marto 2026, http://example.com"
