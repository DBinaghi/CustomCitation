# --- Config form: general ---
msgid "Citation style"
msgstr "Citaĵostilo"

msgid "Choose the citation style for your site."
msgstr "Elektu la citaĵostilon por via retejo."

msgid "Show example ▼"
msgstr "Montri ekzemplon ▼"

msgid "Hide example ▲"
msgstr "Kaŝi ekzemplon ▲"

msgid "Add Collection"
msgstr "Aldoni kolekton"

msgid "Add collection info to citation."
msgstr "Aldonas la titolon de la kolekto al la citaĵo."

